HOST=127.0.0.1
PORT=8000

# Agent execution: auto|claude|mock
ORCH_AGENT_MODE=claude
ORCH_DEFAULT_PERMISSION_MODE=bypassPermissions
ORCH_TOKEN=__GENERATED_BY_SETUP__
ORCH_SKILL_REPOS=

# Optional storage roots. Defaults are repo-local and ignored by git.
# ORCH_DATA_ROOT=.orch/data
# ORCH_CONFIG_ROOT=.orch/config

