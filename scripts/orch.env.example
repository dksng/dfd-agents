HOST=127.0.0.1
PORT=8000

# Agent execution: auto|claude|copilot|mock
ORCH_AGENT_MODE=claude
ORCH_DEFAULT_PERMISSION_MODE=bypassPermissions
ORCH_TOKEN=__GENERATED_BY_SETUP__
ORCH_SKILL_REPOS=

# Optional storage roots. Defaults are repo-local and ignored by git.
# ORCH_DATA_ROOT=.orch/data
# ORCH_CONFIG_ROOT=.orch/config

# Maximum single JSONL event size read from Claude stdout.
# ORCH_CLAUDE_STREAM_LIMIT_BYTES=16777216

# GitHub Copilot CLI command and Copilot-specific tool defaults.
# ORCH_COPILOT_COMMAND=copilot
# ORCH_COPILOT_STREAM_LIMIT_BYTES=16777216
# ORCH_DEFAULT_COPILOT_ALLOWED_TOOLS=write,shell(python3:*),shell(git:*)
# ORCH_DEFAULT_COPILOT_DISALLOWED_TOOLS=
